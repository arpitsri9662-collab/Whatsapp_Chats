<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h3>All Chats</h3>
    <form method="GET" action="/chats/new">
    <button>New Chat</button>
    </form>
    <br><br>
    <% for(chat of chats) { %>
    <div class="chat">
        <p><b>From :</b> <i><%= chat.from %> </i></p>
        <div class="msg">
        <p> <%= chat.msg %> </p>
        <form method="GET" action="/chats/<%=chat._id%>/edit">
            <button id="edit">Edit</button>
        </form>
        <br>
        <form method="POST" action="/chats/<%=chat._id%>?_method=DELETE">
            <button id="edit">Delete</button>
        </form>
        </div>
        <p><b>Received by :</b> <i><%= chat.to %></i></p>
        <hr />
        <p><%= chat.created_at.toString().split(" ")[4] %></p>
        <p><%= chat.created_at.toString().split(" ").slice(0,4).join("-") %></p>
</div>
<br><br>
   <% } %>
</body>
</html>

